# ========================================
# Telegram Bot
# ========================================
BOT_TOKEN=your_telegram_bot_token_here

# Прокси для подключения к Telegram API (нужен в России)
# Купить: proxy6.net или proxyline.net (~100 руб/мес)
# Формат: socks5://логин:пароль@хост:порт
TELEGRAM_PROXY=socks5://user:pass@1.2.3.4:1080

# ========================================
# PostgreSQL
# ========================================
POSTGRES_DB=visabot
POSTGRES_USER=visabot
POSTGRES_PASSWORD=change_me_strong_password

# ========================================
# Redis
# ========================================
REDIS_PASSWORD=change_me_redis_password

# ========================================
# RabbitMQ
# ========================================
RABBITMQ_USER=visabot
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# ========================================
# Security
# ========================================
# Генерация: docker run --rm python:3.12-slim python3 -c \
#   "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=change_me_base64_32bytes_key

# ========================================
# VFS Global — учётные данные личного кабинета
# Зарегистрироваться: https://visa.vfsglobal.com/rus/en/nld
# ========================================
VFS_EMAIL=your_vfs_email@example.com
VFS_PASSWORD=your_vfs_password

# Прокси для обхода Cloudflare на сайте VFS (рекомендуется)
# Можно тот же что и TELEGRAM_PROXY
SITE_PROXY=socks5://user:pass@1.2.3.4:1080

# ========================================
# Captcha Services (для решения reCAPTCHA при логине VFS)
# Зарегистрироваться: https://anti-captcha.com
# ========================================
ANTICAPTCHA_KEY=your_anticaptcha_api_key_here

# ========================================
# Proxy для мониторинга (ротация, опционально)
# ========================================
# PROXY_LIST=socks5://user:pass@1.2.3.4:1080,http://user:pass@5.6.7.8:8080

# ========================================
# Monitoring
# ========================================
MONITOR_INTERVAL_MS=3000
LOG_LEVEL=INFO
